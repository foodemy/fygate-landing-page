---
import { Icon } from "astro-icon/components";
---

<section
  class="mx-auto min-h-[92vh] relative flex justify-center items-center gap-0 px-[5%] pb-15 pt-20 max-lg:min-h-auto max-md:gap-12 max-lg:pt-12 bg-brand-base"
>
  <div
    class="hidden lg:flex pointer-events-none absolute -left-37.5 -top-50 z-0 h-150 w-150 rounded-full bg-brand-primary/10 blur-[120px]"
  >
  </div>
  <!-- <div
    class="pointer-events-none fixed bottom-[10%] -right-25 z-0 h-100 w-100 rounded-full bg-brand-primary/20 blur-[120px]"
  >
  </div> -->
  <!-- <div
    class="pointer-events-none fixed left-[40%] top-[50%] z-0 h-75 w-75 rounded-full bg-brand-primary/20 blur-[120px]"
  > -->
  <div class="flex flex-col items-center">
    <!-- <div
        class="mb-8 inline-flex animate-[fade-up_0.6s_ease_both] items-center gap-2 rounded-full border border-[rgba(126,203,69,0.25)] bg-brand-primary-muted px-4 py-1.5 text-[0.78rem] font-semibold uppercase tracking-[0.08em] text-brand-primary-soft before:h-1.5 before:w-1.5 before:rounded-full before:bg-brand-primary before:content-[''] before:animate-[pulse-dot_1.8s_ease-in-out_infinite]"
      >
        Food Technology · GATE 2027
      </div> -->
    <h1
      class="mb-6 text-brand-contrast animate-[fade-up_0.6s_0.1s_ease_both] font-serif text-[clamp(2.6rem,4.5vw,4.2rem)] leading-[1.05] font-black text-center tracking-[-0.04em]"
    >
      <span class="inline-block relative text-brand-contrast">Crack GATE</span>
      <em class="block italic font-bold text-brand-primary text-shadow-lg"
        >with a plan,</em
      >
      not just prep.
    </h1>
    <p
      class="mb-10 text-center max-w-120 animate-[fade-up_0.6s_0.2s_ease_both] leading-[1.7] font-light text-brand-contrast-muted"
    >
      fyGATE is a structured, mentor-led coaching program designed specifically
      for Food Technology students — with video lectures, module-based
      scheduling, PYQs, mock tests, and 1-on-1 mentorship all in one place.
    </p>
    <div
      class="flex items-center justify-center animate-[fade-up_0.6s_0.3s_ease_both] flex-wrap gap-4"
    >
      <a
        href="https://youtube.com/playlist?list=PLU1Lc2In5F87XqV6QDDpfdBkbkUthu7oF"
        target="_blank"
        class="inline-flex items-center justify-center max-md:min-w-80 h-13 gap-2 rounded-full bg-brand-primary px-6 text-[0.95rem] font-bold text-brand-contrast transition hover:-translate-y-0.5 hover:bg-brand-primary-soft hover:shadow-brand-primary-soft hover:shadow-2xl"
      >
        <Icon name="play-circle-line" class="text-3xl text-brand-contrast" />
        Watch Demo Videos
      </a>
      <a
        href="#cta"
        class="inline-flex max-md:min-w-80 items-center justify-center text-center h-13 gap-2 rounded-full border border-brand-border px-7.5 py-3.5 text-[0.95rem] font-medium text-brand-foreground transition hover:border-brand-contrast hover:text-brand-contrast"
      >
        Notify Me for Upcoming Batch <Icon
          name="arrow-down-line"
          class="text-3xl"
        />
      </a>
    </div>
  </div>
</section>
