---
import { Icon } from "astro-icon/components";
---

<footer
  class="flex flex-wrap items-center justify-between gap-4 border-t border-brand-border px-6 py-8 max-[900px]:flex-col max-[900px]:text-center md:px-10 lg:px-16 bg-brand-contrast"
>
  <div class="text-2xl font-black font-google-sans text-brand-primary">
    fy<span class="text-brand-base">GATE</span>.
  </div>
  <div class="text-[0.78rem] text-brand-surface-alt">© 2026 Foodemy</div>
  <div class="flex flex-wrap items-center gap-3 max-[900px]:justify-center">
    <a
      href="https://www.instagram.com/foodemyOfficial"
      target="_blank"
      aria-label="Instagram"
      class="rounded-full border border-brand-border px-3 py-1.5 text-[0.82rem] text-brand-surface-alt no-underline transition-colors duration-200 hover:border-brand-primary/30 hover:text-brand-primary"
      ><Icon name="instagram-line" /></a
    >
    <a
      href="https://www.linkedin.com/company/foodemyOfficial"
      target="_blank"
      aria-label="LinkedIn"
      class="rounded-full border border-brand-border px-3 py-1.5 text-[0.82rem] text-brand-surface-alt no-underline transition-colors duration-200 hover:border-brand-primary/30 hover:text-brand-primary"
      ><Icon name="linkedin-fill" /></a
    >
    <a
      href="https://youtube.com/@foodemy"
      target="_blank"
      aria-label="YouTube"
      class="rounded-full border border-brand-border px-3 py-1.5 text-[0.82rem] text-brand-surface-alt no-underline transition-colors duration-200 hover:border-brand-primary/30 hover:text-brand-primary"
      ><Icon name="youtube-line" /></a
    >
  </div>
</footer>
