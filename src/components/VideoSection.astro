---
import { Icon } from "astro-icon/components";
---

<section class="px-6 py-24 bg-brand-base md:px-10 lg:px-16" id="videos">
  <div class="mx-auto max-w-7xl">
    <div
      class="grid grid-cols-1 gap-8 items-center mt-14 lg:grid-cols-2"
      data-animate
    >
      <div class="max-w-xl">
        <div
          class="mb-4 flex items-center gap-2.5 font-mono text-xs tracking-widest text-brand-primary uppercase before:h-px before:w-6 before:bg-brand-primary before:content-['']"
        >
          Demo Videos
        </div>
        <h2
          class="mb-4 font-serif text-4xl font-black tracking-tight leading-tight md:text-5xl"
        >
          See it before you <em class="italic font-bold text-brand-primary"
            >decide</em
          >
        </h2>
        <p
          class="mb-5 text-base font-light leading-relaxed text-brand-foreground-muted"
        >
          Before you commit, see how our video lectures look and feel. Our demo
          playlist gives you a real preview of the teaching style, depth, and
          clarity you'll experience throughout the course.
        </p>
        <ul class="flex flex-col gap-3 mb-7 list-none">
          <li class="flex gap-2.5 items-center text-sm text-brand-foreground-muted">
            <Icon
              name="check-line"
              class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-brand-primary/40 bg-brand-primary-muted text-[10px] font-bold text-brand-primary"
            />
            Clear explanations of complex concepts
          </li>
          <li class="flex gap-2.5 items-center text-sm text-brand-foreground-muted">
            <Icon
              name="check-line"
              class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-brand-primary/40 bg-brand-primary-muted text-[10px] font-bold text-brand-primary"
            />
            Structured, topic-wise lecture format
          </li>
          <li class="flex gap-2.5 items-center text-sm text-brand-foreground-muted">
            <Icon
              name="check-line"
              class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-brand-primary/40 bg-brand-primary-muted text-[10px] font-bold text-brand-primary"
            />
            Pre-recorded — rewatch anytime, at any speed
          </li>
          <li class="flex gap-2.5 items-center text-sm text-brand-foreground-muted">
            <Icon
              name="check-line"
              class="flex h-4 w-4 shrink-0 items-center justify-center rounded-full border border-brand-primary/40 bg-brand-primary-muted text-[10px] font-bold text-brand-primary"
            />
            Covers both theory and exam application
          </li>
        </ul>
        <!-- <a
          href="https://youtube.com/playlist?list=PLU1Lc2In5F87XqV6QDDpfdBkbkUthu7oF"
          target="_blank"
          class="inline-flex gap-2 items-center px-8 py-3.5 text-base font-bold rounded-full transition bg-brand-primary text-brand-base hover:-translate-y-0.5 hover:bg-brand-primary-soft hover:shadow-lg hover:shadow-brand-primary/30"
        >
          <span
            class="flex justify-center items-center text-2xl font-light font-icons"
            >play_circle</span
          > Watch Full Demo Playlist
        </a> -->
      </div>

      <div
        class="relative h-0 w-full overflow-hidden rounded-2xl border-brand-primary pb-[56.25%]"
      >
        <iframe
          src="https://www.youtube.com/embed/videoseries?si=NtYiZdP5LW0Sbn2w&list=PLU1Lc2In5F87XqV6QDDpfdBkbkUthu7oF"
          title="YouTube video player"
          loading="lazy"
          style={{
            position: "absolute",
            top: 0,
            left: 0,
            width: "100%",
            height: "100%",
          }}
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        ></iframe>
      </div>
    </div>
  </div>
</section>
