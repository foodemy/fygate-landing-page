<div
  class="group/stats flex justify-center gap-0 border-y border-brand-border px-[5%] py-8 max-md:flex-wrap"
  data-animate
  data-wrapped="false"
>
  <div
    class="flex-1 border-r border-brand-border px-6 text-center last:border-r-0 max-md:min-w-37.5 max-md:px-0 max-md:py-5 group-data-[wrapped=true]/stats:border-r-0 group-data-[wrapped=true]/stats:max-md:border-b group-data-[wrapped=true]/stats:max-md:border-brand-border data-[last-row=true]:max-md:border-b-0"
    data-stats-item
    data-last-row="false"
  >
    <div
      class="mb-1 font-serif text-[2.2rem] leading-none font-black tracking-[-0.03em] text-brand-primary"
    >
      27
    </div>
    <div class="text-[0.78rem] font-normal text-brand-foreground-muted">
      Structured Modules
    </div>
  </div>
  <div
    class="flex-1 border-r border-brand-border px-6 text-center last:border-r-0 max-md:min-w-37.5 max-md:px-0 max-md:py-5 group-data-[wrapped=true]/stats:border-r-0 group-data-[wrapped=true]/stats:max-md:border-b group-data-[wrapped=true]/stats:max-md:border-brand-border data-[last-row=true]:max-md:border-b-0"
    data-stats-item
    data-last-row="false"
  >
    <div
      class="mb-1 font-serif text-[2.2rem] leading-none font-black tracking-[-0.03em] text-brand-primary"
    >
      80+
    </div>
    <div class="text-[0.78rem] font-normal text-brand-foreground-muted">Videos</div>
  </div>
  <div
    class="flex-1 border-r border-brand-border px-6 text-center last:border-r-0 max-md:min-w-37.5 max-md:px-0 max-md:py-5 group-data-[wrapped=true]/stats:border-r-0 group-data-[wrapped=true]/stats:max-md:border-b group-data-[wrapped=true]/stats:max-md:border-brand-border data-[last-row=true]:max-md:border-b-0"
    data-stats-item
    data-last-row="false"
  >
    <div
      class="mb-1 font-serif text-[2.2rem] leading-none font-black tracking-[-0.03em] text-brand-primary"
    >
      100%
    </div>
    <div class="text-[0.78rem] font-normal text-brand-foreground-muted">
      PYQs Topic-Wise Solved
    </div>
  </div>
  <div
    class="flex-1 border-r border-brand-border px-6 text-center last:border-r-0 max-md:min-w-37.5 max-md:px-0 max-md:py-5 group-data-[wrapped=true]/stats:border-r-0 group-data-[wrapped=true]/stats:max-md:border-b group-data-[wrapped=true]/stats:max-md:border-brand-border data-[last-row=true]:max-md:border-b-0"
    data-stats-item
    data-last-row="false"
  >
    <div
      class="mb-1 font-serif text-[2.2rem] leading-none font-black tracking-[-0.03em] text-brand-primary"
    >
      1:1
    </div>
    <div class="text-[0.78rem] font-normal text-brand-foreground-muted">
      Mentorship Check-ins
    </div>
  </div>
</div>

<script>
  const container = document.querySelector("[data-wrapped]");
  const items = container?.querySelectorAll("[data-stats-item]");

  function updateWrappedState() {
    if (!container || !items || items.length === 0) return;

    const tops = Array.from(items).map((item) => item.offsetTop);
    const minTop = Math.min(...tops);
    const maxTop = Math.max(...tops);
    const isWrapped = maxTop !== minTop;

    items.forEach((item) => {
      item.setAttribute(
        "data-last-row",
        item.offsetTop === maxTop ? "true" : "false",
      );
    });

    container.setAttribute("data-wrapped", isWrapped ? "true" : "false");
  }

  const resizeObserver = new ResizeObserver(updateWrappedState);
  if (container) {
    resizeObserver.observe(container);
  }

  window.addEventListener("load", updateWrappedState);
  window.addEventListener("resize", updateWrappedState);
  updateWrappedState();
</script>
